# Entorno
NODE_ENV=development
PORT=4000

# Base de datos (Supabase Postgres — mismo formato en dev y prod)
DATABASE_URL="postgresql://usuario:password@host:5432/postgres"

# JWT
JWT_SECRET="cambia-este-valor-por-un-secreto-largo-y-aleatorio"
JWT_REFRESH_SECRET="cambia-este-valor-por-otro-secreto-largo-y-aleatorio"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seguridad
BCRYPT_SALT_ROUNDS=10

# CORS (URL del frontend Next.js)
CORS_ORIGIN=http://localhost:3000
