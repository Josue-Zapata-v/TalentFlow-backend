# Entorno
NODE_ENV=development
PORT=4000

# Base de datos (Supabase Postgres — mismo formato en dev y prod)
# DATABASE_URL: connection pooling (Transaction mode, puerto 6543) — la usa la app en runtime
# DIRECT_URL: conexion directa (puerto 5432) — la usa Prisma Migrate
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# JWT
JWT_SECRET="cambia-este-valor-por-un-secreto-largo-y-aleatorio"
JWT_REFRESH_SECRET="cambia-este-valor-por-otro-secreto-largo-y-aleatorio"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seguridad
BCRYPT_SALT_ROUNDS=10

# CORS (URLs del frontend Next.js, separadas por coma — dev y prod a la vez)
CORS_ORIGIN=http://localhost:3000,https://talent-flow-frontend-zeta.vercel.app
